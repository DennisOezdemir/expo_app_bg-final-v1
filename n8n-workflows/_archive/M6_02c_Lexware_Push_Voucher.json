    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst eventId = input.body?.event_id || input.event_id;\nconst projectId = input.body?.project_id || input.project_id;\nconst payload = input.body?.payload || input.payload || {};\n\nreturn {\n  json: {\n    event_id: eventId,\n    project_id: projectId || null,\n    purchase_invoice_id: payload.purchase_invoice_id,\n    lexware_contact_id: payload.lexware_contact_id || null,\n    step_key: `lexware_push:${payload.purchase_invoice_id}`\n  }\n};"
      },
