    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT pi.*, pi.expense_category::text as expense_cat,\n       pi.pdf_storage_path,\n       s.lexware_contact_id\nFROM purchase_invoices pi\nJOIN suppliers s ON s.id = pi.supplier_id\nWHERE pi.id = '{{ $('Parse Event Data').item.json.purchase_invoice_id }}'::uuid;",
        "options": {}
      },
      "id": "350f2af2-305b-4d91-b158-755e5848f843",
      "name": "Load Invoice",
      "type": "n8n-nodes-base.postgres",
