    {
      "parameters": {
        "jsCode": "const inv = $json;\nconst eventData = $('Parse Event Data').first().json;\n\n// Use contact from event payload (freshly created) or from supplier record\nconst contactId = eventData.lexware_contact_id || inv.lexware_contact_id || null;\n\n// Category mapping - verified UUIDs from Lexware posting-categories API\nconst catMap = {\n  'SUBCONTRACTOR': 'efa82f43-fd85-11e1-a21f-0800200c9a66', // Fremdleistungen\n  'MATERIAL': '97938aa5-c5a7-4d31-bdac-a19209ba432e'        // Wareneinkauf\n};\nconst categoryId = catMap[inv.expense_cat] || 'efa82f42-fd85-11e1-a21f-0800200c9a66';\n\nconst formatDate = (d) => d ? d.substring(0, 10) + 'T00:00:00.000+01:00' : null;\n\nconst voucher = {\n  type: 'purchaseinvoice',\n  voucherNumber: inv.invoice_number,\n  voucherDate: formatDate(inv.invoice_date),\n  totalGrossAmount: parseFloat(inv.total_gross),\n  totalTaxAmount: parseFloat(inv.vat_amount || 0),\n  taxType: 'gross',\n  remark: 'Importiert aus BauGenius',\n  voucherItems: [{\n    amount: parseFloat(inv.total_gross),\n    taxAmount: parseFloat(inv.vat_amount || 0),\n    taxRatePercent: parseFloat(inv.vat_percent || 19),\n    categoryId: categoryId\n  }]\n};\nif (inv.due_date) voucher.dueDate = formatDate(inv.due_date);\nif (contactId) voucher.contactId = contactId;\n\nreturn { json: { voucher_payload: voucher, voucher_json: JSON.stringify(voucher), invoice_id: inv.id, invoice_number: inv.invoice_number, pdf_storage_path: inv.pdf_storage_path || '' } }"
      },
