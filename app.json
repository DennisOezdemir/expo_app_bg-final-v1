{
  "expo": {
    "name": "BAUGENIUS",
    "slug": "baugenius",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "baugenius",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.baugenius",
      "infoPlist": {
        "NSCameraUsageDescription": "BauGenius benötigt Kamerazugriff für Begehungsfotos.",
        "NSPhotoLibraryUsageDescription": "BauGenius benötigt Fotozugriff für die Baudokumentation.",
        "NSLocationWhenInUseUsageDescription": "BauGenius benötigt den Standort für die Baustellenzuordnung."
      }
    },
    "android": {
      "package": "com.baugenius",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#09090b",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/YOUR_PROJECT_ID",
      "fallbackToCacheTimeout": 3000
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://baugenius.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Erlaubt BauGenius Zugriff auf Fotos für die Baudokumentation.",
          "cameraPermission": "Erlaubt BauGenius die Kamera für Begehungsfotos zu nutzen."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_PROJECT_ID"
      }
    }
  }
}
